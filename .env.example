# Copy to .env and fill in. NEVER commit the real .env.
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here

# Scopes the app requests at install time.
SHOPIFY_SCOPES=read_orders,read_products,read_inventory

# Public URL of this app (your tunnel URL in dev, your host URL in prod).
APP_URL=https://your-app.onrender.com

# App Store listing handle used for Shopify-hosted plan changes.
# Must match the app's real handle (admin shows it as /apps/<handle>).
SHOPIFY_APP_HANDLE=restocked-7

# Shopify Admin API version.
SHOPIFY_API_VERSION=2026-04

# Random secret for signing session cookies (generate any long random string).
APP_SECRET=change_me_to_a_long_random_string

# Postgres connection (optional in dev; falls back to in-memory if unset).
DATABASE_URL=

# Default supplier lead time (days) used until a merchant sets their own.
DEFAULT_LEAD_TIME_DAYS=30
